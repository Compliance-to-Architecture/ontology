  {
    "applicability_test_id": "APP-EUAI-HIGH-RISK-ANNEXIII-001",
    "authority_id": "eu-ai-act@2024-1689",
    "clause": "Annex III(4) read with Art. 6(2)",
    "applies_when": [
      { "facet": "aiSystemIsAiSystem", "operator": "eq", "value": true },
      { "facet": "aiSystemPlacedOnMarketOrPutIntoServiceIn", "operator": "in", "value": ["JUR-EU", "JUR-EEA"] },
      { "facet": "aiSystemUseCase", "operator": "in", "value": ["recruitment", "selection", "employment-management", "task-allocation", "performance-and-behavior-monitoring"] },
