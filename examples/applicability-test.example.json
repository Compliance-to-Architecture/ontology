      { "facet": "aiSystemIsSafetyComponentExempt", "operator": "eq", "value": false }
    ],
    "role_sensitive": true,
    "roles": ["provider", "deployer", "employer"],
    "output": {
      "obligation_set_id": "OBLSET-EUAI-HIGHRISK-CORE",
      "risk_class": "high-risk"
    },
    "version": "1.0.0",
    "source_provenance": [
      { "authority_id": "eu-ai-act@2024-1689", "clause": "Art. 6(2)" },
