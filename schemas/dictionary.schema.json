{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://compliancetoarchitecture.com/schemas/dictionary.schema.json",
  "title": "Dictionary",
  "description": "A versioned, content-addressable set of canonical terms used across rule packs, controls, evidence and reasoning. Each dictionary is a self-contained source of meaning for one category (obligation-category, control-category, evidence-type, etc.). Dictionaries are the resolution target for term references inside rule packs and engines — engines MUST NOT invent terms outside a published dictionary.",
  "type": "object",
  "required": ["schemaVersion", "id", "displayName", "version", "publishedAt", "category", "terms"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "regunav.dictionary.v1"
    },
    "id": {
      "type": "string",
      "pattern": "^regunav:dictionary:[a-z0-9-]+$",
      "description": "Stable identifier. Format: regunav:dictionary:<category-slug>."
    },
    "displayName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Semver. Bumping major implies term removal or breaking re-definition."
    },
    "publishedAt": { "type": "string", "format": "date" },
    "supersedes": {
      "type": "string",
      "pattern": "^regunav:dictionary:[a-z0-9-]+@[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "Optional. Previous dictionary id@version this one replaces."
    },
    "category": {
      "type": "string",
      "enum": [
        "obligation-category",
        "control-category",
        "evidence-type",
        "evidence-frequency",
        "authority-category",
        "architecture-capability",
        "actor-role",
        "reason-code",
        "jurisdiction",
        "regulator",
        "risk-class"
      ]
    },
    "terms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "term", "definition"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+:[a-z0-9._-]+$",
            "description": "Format: <category-slug>:<term-slug>. Example: obligation-category:privacy."
          },
          "term": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical key. MUST match the value used in the source TypeScript enum or framework field."
          },
          "definition": {
            "type": "string",
            "minLength": 1
          },
          "synonyms": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "references": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["authorityId", "clause"],
              "properties": {
                "authorityId": { "type": "string" },
                "clause":      { "type": "string" },
                "url":         { "type": "string", "format": "uri" }
              },
              "additionalProperties": false
            }
          },
          "tags": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9-]+$" },
            "uniqueItems": true
          },
          "deprecated": {
            "type": "object",
            "required": ["since", "replacedBy"],
            "properties": {
              "since":      { "type": "string", "format": "date" },
              "replacedBy": { "type": "string" },
              "reason":     { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
