{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://compliancetoarchitecture.com/schemas/layer/audit-pack.schema.json",
  "title": "AuditPack (L12)",
  "description": "A regulator/board/auditor deliverable bundling evidence + signatures + manifest.",
  "type": "object",
  "required": ["id", "title", "forAuthority", "periodStart", "periodEnd", "sections", "disclaimerEmbedded"],
  "properties": {
    "id":           { "type": "string", "pattern": "^PACK-[A-Z0-9-]+$" },
    "title":        { "type": "string", "minLength": 1 },
    "forAuthority": { "type": "string" },
    "forSystem":    { "type": "string" },
    "periodStart":  { "type": "string", "format": "date" },
    "periodEnd":    { "type": "string", "format": "date" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "evidenceIds", "required"],
        "properties": {
          "title":         { "type": "string", "minLength": 1 },
          "evidenceIds":   { "type": "array", "items": { "type": "string", "pattern": "^EV-" } },
          "required":      { "type": "boolean" },
          "authorityRefs": { "type": "array", "items": { "type": "object", "required": ["authority", "clause"], "properties": { "authority": { "type": "string" }, "clause": { "type": "string" } } } }
        }
      }
    },
    "disclaimerEmbedded": { "type": "boolean", "const": true, "description": "MUST be true. Audit packs without the framework legal disclaimer are non-conformant." },
    "manifestSha256":     { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "additionalProperties": false
}
