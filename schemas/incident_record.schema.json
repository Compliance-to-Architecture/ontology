{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://compliancetoarchitecture.com/schemas/evidence/incident_record.schema.json",
  "title": "Incident record evidence",
  "description": "Lifecycle record of a security/privacy/AI incident (DORA Art. 18, GDPR Art. 33, EU AI Act Art. 73). Mandatory regulator-deadline tracking.",
  "type": "object",
  "required": ["id", "severity", "status", "title", "discoveredAt"],
  "properties": {
    "id":              { "type": "string", "pattern": "^EV-INC-[A-Z0-9-]+$" },
    "severity":        { "type": "string", "enum": ["low","medium","high","critical","catastrophic"] },
    "status":          { "type": "string", "enum": ["open","contained","resolved","reported","closed"] },
    "title":           { "type": "string", "minLength": 1 },
    "description":     { "type": "string" },
    "discoveredAt":    { "type": "string", "format": "date-time" },
    "containedAt":     { "type": "string", "format": "date-time" },
    "resolvedAt":      { "type": "string", "format": "date-time" },
    "reportedAt":      { "type": "string", "format": "date-time" },
    "regulatorDeadlines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["authority", "dueAt"],
        "properties": {
          "authority":    { "type": "string" },
          "dueAt":        { "type": "string", "format": "date-time" },
          "submittedAt":  { "type": "string", "format": "date-time" },
          "submissionRef":{ "type": "string" }
        }
      }
    },
    "affectedSubjects": { "type": "integer", "minimum": 0 },
    "affectedSystems":  { "type": "array", "items": { "type": "string" } },
    "rootCause":        { "type": "string" },
    "remediationPlan":  { "type": "string" },
    "frameworks":       { "type": "array", "items": { "type": "string" } },
    "controls":         { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
