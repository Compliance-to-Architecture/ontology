{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://compliancetoarchitecture.com/schemas/rule-pack-manifest.schema.json",
  "title": "RulePackManifest",
  "description": "Specialised manifest for a regulation, standard or framework. Validates the manifest envelope (kind === 'rule-pack') AND the rule-pack payload (authority, jurisdictions, applicable entity roles, included rule groups, artefact pointers). A rule-pack manifest is what an engine 'installs' to evaluate obligations from a specific regulation — separate from the runtime data the manifest points to.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "kind",
    "displayName",
    "version",
    "publishedAt",
    "publisher",
    "license",
    "status",
    "payload"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "regunav.manifest.v1" },
    "id":            { "type": "string", "pattern": "^regunav:manifest:rule-pack:[a-z0-9][a-z0-9.-]*:[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "kind":          { "type": "string", "const": "rule-pack" },
    "displayName":   { "type": "string", "minLength": 1 },
    "description":   { "type": "string" },
    "version":       { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "publishedAt":   { "type": "string", "format": "date" },
    "supersedes":    { "type": "string", "pattern": "^regunav:manifest:rule-pack:[a-z0-9][a-z0-9.-]*:[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "publisher": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":    { "type": "string", "minLength": 1 },
        "url":     { "type": "string", "format": "uri" },
        "contact": { "type": "string" }
      },
      "additionalProperties": false
    },
    "license":            { "type": "string" },
    "status":             { "type": "string", "enum": ["active", "preview", "deprecated", "retired"] },
    "requiredDictionaries": {
      "type": "array",
      "items": { "type": "string", "pattern": "^regunav:dictionary:[a-z0-9-]+(@[0-9]+\\.[0-9]+\\.[0-9]+)?$" },
      "uniqueItems": true
    },
    "requiredProfiles": {
      "type": "array",
      "items": { "type": "string", "pattern": "^regunav\\.(core|conformance|connector)\\.v[0-9]+$" },
      "uniqueItems": true
    },
    "requiredManifests": {
      "type": "array",
      "items": { "type": "string", "pattern": "^regunav:manifest:[a-z][a-z0-9-]*:[a-z0-9][a-z0-9.-]*:[0-9]+\\.[0-9]+\\.[0-9]+$" },
      "uniqueItems": true
    },
    "integrity": {
      "type": "object",
      "required": ["algorithm", "hash"],
      "properties": {
        "algorithm": { "type": "string", "enum": ["sha256"] },
        "hash":      { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "signedBy":  { "type": "string" },
        "signature": { "type": "string" }
      },
      "additionalProperties": false
    },
    "payload": {
      "type": "object",
      "required": [
        "authority",
        "jurisdictions",
        "appliesTo",
        "includedRuleGroups",
        "artefacts"
      ],
      "properties": {
        "authority": {
          "type": "object",
          "required": ["id", "shortName", "citation"],
          "properties": {
            "id":              { "type": "string", "pattern": "^[a-z][a-z0-9-]*@[a-z0-9.-]+$", "description": "Format: <slug>@<version-tag>. Example: eu-ai-act@2024-1689." },
            "shortName":       { "type": "string", "minLength": 1 },
            "title":           { "type": "string" },
            "citation":        { "type": "string", "minLength": 1 },
            "url":             { "type": "string", "format": "uri" },
            "publisher":       { "type": "string" },
            "publishedAt":     { "type": "string", "format": "date" },
            "inForceFrom":     { "type": "string", "format": "date" },
            "applicableFrom":  { "type": "string", "format": "date" },
            "category":        { "type": "string", "description": "Resolves to dictionary:authority-category." }
          },
          "additionalProperties": false
        },
        "jurisdictions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "description": "ISO-3166 region codes or canonical jurisdiction slugs (EU, EEA, US, UK, CA-ON, etc). Resolved against dictionary:jurisdiction when that dictionary lands."
        },
        "appliesTo": {
          "type": "object",
          "description": "Coarse applicability filter; precise applicability lives in the AST artefact.",
          "properties": {
            "domains":     { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "entityRoles": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true, "description": "Resolves to dictionary:actor-role for AI value-chain roles." },
            "sectors":     { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
            "systemTypes": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
          },
          "additionalProperties": false
        },
        "includedRuleGroups": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "description": "Logical groups of rules the pack covers (applicability, risk_classification, governance, documentation, transparency, human_oversight, post_market_monitoring, incident_reporting, etc). A group with zero rules is forbidden — see no-stubs gate."
        },
        "artefacts": {
          "type": "object",
          "description": "Relative paths (from this manifest file) to the data layers that satisfy the rule pack. A path that does not exist is treated as 'not yet shipped' for the named layer.",
          "properties": {
            "framework":        { "type": "string", "description": "TS module re-export — packages/frameworks/src/<slug>.ts" },
            "applicabilityAst": { "type": "string", "description": "applicability-ast.v1 JSON (PR 3)" },
            "controlMappings":  { "type": "string", "description": "crosswalk JSON" },
            "evidenceTemplates":{ "type": "string", "description": "evidence-template manifest" },
            "fixtures":         { "type": "string", "description": "Path to fixtures directory: worked applicability cases" }
          },
          "additionalProperties": false
        },
        "deadlines": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "date"],
            "properties": {
              "name":     { "type": "string" },
              "date":     { "type": "string", "format": "date" },
              "appliesTo":{ "type": "string", "description": "Optional sub-rule group name." },
              "url":      { "type": "string", "format": "uri" }
            },
            "additionalProperties": false
          },
          "description": "Public statutory deadlines tied to this pack."
        },
        "supervisoryBodies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Named regulators or supervisory authorities. Resolves to dictionary:regulator when that dictionary lands."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
